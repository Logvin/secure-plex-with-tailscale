# Tailscale auth key from https://login.tailscale.com/admin/settings/keys
# Use a reusable, ephemeral, pre-authorized key tagged with tag:plex-stack
TS_AUTHKEY=

# The CIDR the subnet router will advertise to your tailnet.
# Must match the network defined in docker-compose.yml.
TS_ROUTES=172.30.0.0/24

# Your timezone (used by the *arr containers)
TZ=America/Phoenix

# Optional: User/group IDs for *arr containers (defaults are usually fine)
PUID=1000
PGID=1000

# Plex claim token from https://www.plex.tv/claim/
# Only needed for first-time Plex setup; expires after 4 minutes
PLEX_CLAIM=
