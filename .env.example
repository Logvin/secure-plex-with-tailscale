# Copy to .env and fill in real values. .env is gitignored.

# Tailscale auth key for the subnet router + SSH sidecar.
# Generate at https://login.tailscale.com/admin/settings/keys
# Recommended settings: reusable, NOT ephemeral, tagged tag:plex-router
TS_AUTHKEY=tskey-auth-xxxxx-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# CIDR that the subnet router will advertise to your tailnet.
# Must match the subnet defined in docker-compose.yml.
TS_ROUTES=172.30.0.0/24

# Your timezone (used by the *arr containers).
TZ=America/Phoenix

# User/group IDs for *arr container file ownership. Defaults are fine.
PUID=1000
PGID=1000
